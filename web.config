<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <clear />

        <!-- 1) SSRF SHIELD -->
        <rule name="BlockProxyExploit" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAny">
            <add input="{REQUEST_URI}" pattern="https?[:/]" />
            <add input="{QUERY_STRING}" pattern="https?[:/]" />
            <add input="{REQUEST_URI}" pattern="bit|cgi-bin|slotxo" />
          </conditions>
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" />
        </rule>

        <!-- 2) Static meta files -->
        <rule name="BypassStaticMetaFiles" stopProcessing="true">
          <match url="^(sitemap\.xml|robots\.txt|favicon\.ico)$" ignoreCase="true" />
          <action type="None" />
        </rule>

        <!-- 3) Legacy paths 404 -->
        <rule name="LegacyPathsNowMissing_Return404" stopProcessing="true">
          <match url="^(home/?|cuponera/?|noticias/?|nivel/(middleschool|elementary)/?)$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="404" statusReason="Not Found" statusDescription="Not Found" />
        </rule>

        <!-- 4) Strip index.html -->
        <rule name="StripIndexHtml" stopProcessing="true">
          <match url="^(.*)index\.html$" ignoreCase="true" />
          <action type="Redirect" url="https://casitaiedis.edu.mx/{R:1}" redirectType="Permanent" />
        </rule>
        
        <!-- 4.1) Strip ALL other .html to enforce native Vue routes (e.g. /daycare.html -> /daycare) -->
        <rule name="StripHtmlExt" stopProcessing="true">
          <match url="^(.*)\.html$" ignoreCase="true" />
          <action type="Redirect" url="https://casitaiedis.edu.mx/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 5) Force HTTPS -->
        <rule name="ForceHTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            <add input="{HTTP_X_FORWARDED_PROTO}" pattern="https" negate="true" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 6) Remove www -->
        <rule name="RemoveWWW" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTP_HOST}" pattern="^www\.casitaiedis\.edu\.mx$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://casitaiedis.edu.mx/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 7) Force canonical host -->
        <rule name="ForceCanonicalHost" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTP_HOST}" pattern="^casitaiedis\.edu\.mx$" negate="true" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://casitaiedis.edu.mx/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 8) Bypass /virtual -->
        <rule name="BypassVirtualDirectory" stopProcessing="true">
          <match url="^virtual/(.*)$" />
          <action type="None" />
        </rule>

        <!-- 9) Reverse proxy to Nuxt -->
        <rule name="ReverseProxyAll" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:16767/{R:1}" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>

    <httpProtocol>
      <customHeaders>
        <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>

  <location path="virtual">
    <system.webServer>

      <!-- Respond to CORS preflight -->
      <rewrite>
        <rules>
          <clear />
          <rule name="OPTIONS /virtual" stopProcessing="true">
            <match url=".*" />
            <conditions>
              <add input="{REQUEST_METHOD}" pattern="OPTIONS" />
            </conditions>
            <action type="CustomResponse" statusCode="204" statusReason="No Content" statusDescription="No Content" />
          </rule>
        </rules>
      </rewrite>

      <!-- CORS headers for /virtual static files -->
      <httpProtocol>
        <customHeaders>
          <remove name="Access-Control-Allow-Origin" />
          <remove name="Access-Control-Allow-Methods" />
          <remove name="Access-Control-Allow-Headers" />
          <remove name="Access-Control-Max-Age" />
          <remove name="Vary" />

          <add name="Access-Control-Allow-Origin" value="https://admin.casitaiedis.edu.mx" />
          <add name="Access-Control-Allow-Methods" value="GET, OPTIONS" />
          <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization, X-Requested-With" />
          <add name="Access-Control-Max-Age" value="86400" />
          <add name="Vary" value="Origin" />
        </customHeaders>
      </httpProtocol>

      <security>
        <requestFiltering>
          <fileExtensions allowUnlisted="true" />
        </requestFiltering>
      </security>

      <staticContent>
        <remove fileExtension="." />
        <mimeMap fileExtension="." mimeType="application/octet-stream" />
      </staticContent>

    </system.webServer>
  </location>
</configuration>