{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/virtual/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://admin.casitaiedis.edu.mx"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, HEAD, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Origin, X-Requested-With, Content-Type, Accept"
        },
        {
          "key": "Vary",
          "value": "Origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/virtual/:path*",
      "destination": "https://admin.casitaiedis.edu.mx/virtual/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/signatures",
      "destination": "https://admin.casitaiedis.edu.mx/signatures",
      "permanent": false
    },
    {
      "source": "/signatures/:path*",
      "destination": "https://admin.casitaiedis.edu.mx/signatures/:path*",
      "permanent": false
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/(.*)\\.html",
      "destination": "/$1",
      "permanent": true
    }
  ]
}